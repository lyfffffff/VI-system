{
  "name": "@yyxxfe/vi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": [
    "**/*.css",
    "**/*.less"
  ],
  "scripts": {
    "build": "vite build"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./theme": {
      "types": "./src/composables/use-vi-theme.ts",
      "import": "./dist/theme.js",
      "default": "./dist/theme.js"
    },
    "./theme-drawer": {
      "types": "./src/components/theme-drawer/index.ts",
      "import": "./dist/theme-drawer.js",
      "default": "./dist/theme-drawer.js"
    },
    "./styles": "./dist/style.css",
    "./styles/tokens": "./dist/style.css",
    "./styles/semantic-vars": "./dist/style.css",
    "./styles/element-plus-mapping": "./dist/style.css",
    "./styles/workbench-mapping": "./dist/style.css",
    "./styles/workbench-overrides": "./dist/style.css"
  },
  "peerDependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "element-plus": "^2.11.3",
    "vue": "^3.5.18"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.1",
    "less": "^4.2.0",
    "vite": "^5.4.11"
  }
}
